{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "paths": {
      "@core/*": ["./src/core/*"],
      "@docmost/*": ["./src/docmost/*"],
      "@mcp/*": ["./src/mcp/*"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
